//@version=5
strategy("Moving Average Crossover Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// Input parameters
fastLength = input.int(12, minval=1, title="Fast EMA Length")
slowLength = input.int(26, minval=1, title="Slow EMA Length")

fastMA = ta.ema(close, fastLength)
slowMA = ta.ema(close, slowLength)

plot(fastMA, color=color.blue, title="Fast EMA")
plot(slowMA, color=color.orange, title="Slow EMA")

longCondition = ta.crossover(fastMA, slowMA)
if longCondition
    strategy.entry("Long", strategy.long)

shortCondition = ta.crossunder(fastMA, slowMA)
if shortCondition
    strategy.entry("Short", strategy.short)

// Close conditions on opposite cross
if ta.crossunder(fastMA, slowMA)
    strategy.close("Long")
if ta.crossover(fastMA, slowMA)
    strategy.close("Short")

stopLossPct = input.float(1.5, title="Stop Loss %", minval=0.1)
takeProfitPct = input.float(3.0, title="Take Profit %", minval=0.1)

if strategy.position_size > 0
    strategy.exit("Exit Long", from_entry="Long", stop=strategy.position_avg_price * (1 - stopLossPct / 100), limit=strategy.position_avg_price * (1 + takeProfitPct / 100))
if strategy.position_size < 0
    strategy.exit("Exit Short", from_entry="Short", stop=strategy.position_avg_price * (1 + stopLossPct / 100), limit=strategy.position_avg_price * (1 - takeProfitPct / 100))
